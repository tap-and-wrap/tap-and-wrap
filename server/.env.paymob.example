# PAYMOB ACCEPT — CARD PAYMENT

# Values supplied by Paymob.
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# Optional. A long random secret used only to sign the
# customer-facing payment-result URL. If omitted, JWT_SECRET
# is used; if JWT_SECRET is also absent, PAYMOB_HMAC_SECRET
# is used.
PAYMOB_RESULT_SECRET=

PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_PAYMENT_KEY_EXPIRATION=3600
PAYMOB_REQUEST_TIMEOUT_MS=25000

# Local values during development.
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Production examples:
# CLIENT_URL=https://tap-and-wrap.com
# SERVER_URL=https://api.tap-and-wrap.com
