# --------------------------------------------------
# CORE
# --------------------------------------------------
NODE_ENV=development
PORT=5000

MONGO_URI=

# Use at least 32 random characters.
JWT_SECRET=

# Frontend origin. No trailing slash.
CLIENT_URL=http://localhost:5173

# Optional comma-separated extra frontend origins.
CLIENT_URLS=

# Public backend origin. No trailing slash.
SERVER_URL=http://localhost:5000

# --------------------------------------------------
# ADMIN SESSION
# --------------------------------------------------
ADMIN_COOKIE_NAME=tap_wrap_admin
ADMIN_COOKIE_DAYS=7
ADMIN_TOKEN_EXPIRES_IN=7d

# Local: lax
# Vercel frontend + Render backend: none
# Same parent custom domain, such as shop.com + api.shop.com: lax
ADMIN_COOKIE_SAME_SITE=lax

# Usually leave blank. Set only when intentionally sharing
# the cookie across subdomains, e.g. .tapandwrap.com
ADMIN_COOKIE_DOMAIN=

# --------------------------------------------------
# CLOUDINARY
# --------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --------------------------------------------------
# STORE DEFAULTS
# Admin settings stored in MongoDB override these after initialization.
# --------------------------------------------------
WHATSAPP_NUMBER=+201508216472
INSTAPAY_HANDLE=
VODAFONE_CASH_NUMBER=
SHIPPING_CAIRO_GIZA=80
SHIPPING_OTHER_GOVERNORATES=120
LOW_STOCK_THRESHOLD=5

# --------------------------------------------------
# EMAIL — OPTIONAL
# EMAIL_APP_PASSWORD is the name already used by this project.
# --------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=Tap & Wrap
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=
ADMIN_NOTIFICATION_EMAIL=

# --------------------------------------------------
# PAYMOB — OPTIONAL UNTIL CREDENTIALS ARRIVE
# --------------------------------------------------
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_RESULT_SECRET=
PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_PAYMENT_KEY_EXPIRATION=3600
PAYMOB_REQUEST_TIMEOUT_MS=25000

# --------------------------------------------------
# ADMIN SEED — USE ONLY WHEN RUNNING seed:admin
# --------------------------------------------------
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
